{
  "outputDirectory": "dist",
  "regions": ["sfo1"],
  "functions": {
    "api/**": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/join/(.*)",
      "destination": "/join.html"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
